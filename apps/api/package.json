{
  "name": "@coterapeuta/api",
  "version": "1.0.0",
  "private": true,
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "scripts": {
    "dev": "ts-node --project tsconfig.json src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "start:prod": "npx prisma db push --accept-data-loss && node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@coterapeuta/shared": "*",
    "@prisma/client": "5.22.0",
    "bcrypt": "5.1.1",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.21.1",
    "jsonwebtoken": "9.0.2",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "5.0.2",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.7",
    "@types/node": "22.9.0",
    "@types/supertest": "^7.2.0",
    "fast-check": "3.23.1",
    "prisma": "5.22.0",
    "supertest": "^7.2.2",
    "ts-node": "10.9.2",
    "typescript": "5.6.3",
    "vitest": "2.1.5"
  }
}
